ENGINE_TOP_N=15
ENGINE_QUOTE_ASSET=USDT
# Optional explicit universe override (recommended for fixed institutional basket)
# ENGINE_UNIVERSE_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,XRPUSDT,ADAUSDT,DOGEUSDT,LTCUSDT,LINKUSDT,BCHUSDT,TRXUSDT,ETCUSDT,XLMUSDT,EOSUSDT,XMRUSDT,ATOMUSDT
ENGINE_UNIVERSE_SOURCE=coingecko_market_cap
COINGECKO_API_BASE_URL=https://api.coingecko.com/api/v3
ENGINE_UNIVERSE_STRICT_STABLE_FILTER=true
ENGINE_RAW_TIMEFRAME=1m
ENGINE_RUN_START_UTC=2020-01-01T00:00:00Z
# ENGINE_RUN_END_UTC=2026-02-24T00:00:00Z

ENGINE_DATA_ROOT=engine/data
ENGINE_ARTIFACT_ROOT=engine/artifacts
ENGINE_AGGREGATE_TIMEFRAMES=1m,5m,15m,1h,4h,1d,1w

BINANCE_ARCHIVE_BASE_URL=https://data.binance.vision/data/spot/monthly/klines
BINANCE_API_BASE_URL=https://api.binance.com/api/v3

ENGINE_TIER1_HOURS=6
ENGINE_TIER2_HOURS=24
ENGINE_TIER3_DAYS=7
ENGINE_OPTIMIZATION_SCHEDULE_HOURS=24

ENGINE_OPTIMIZATION_ENABLED=true
ENGINE_OPTIMIZATION_TIMEFRAMES=15m
# Baseline-first policy: 15m primary, 5m confirm-only.
ENGINE_BASELINE_PRIMARY_TIMEFRAME=15m
ENGINE_BASELINE_CONFIRM_TIMEFRAMES=5m
ENGINE_FEATURE_TIMEFRAMES=5m,15m,1h,4h,1d,1w
ENGINE_OPTIMIZATION_WINDOWS=all,30d,90d,360d
ENGINE_OPTIMIZATION_GATE_MODES=gated,ungated
ENGINE_LEADERBOARD_MODES=score,return
ENGINE_OPTIMIZATION_LONG_ONLY=true
ENGINE_OBJECTIVE_MODE=beat_spot_each_window
ENGINE_OPTIMIZATION_MAX_ROUNDS=8
ENGINE_OPT_TARGET_VALIDATION_PASS_RATE=0.55
ENGINE_OPT_TARGET_ALL_WINDOW_ALPHA_FLOOR=-0.02
ENGINE_OPT_TARGET_DEPLOY_ALPHA_FLOOR=0.0
ENGINE_OPT_TARGET_DEPLOY_SYMBOL_RATIO=0.30
ENGINE_RULE_ENGINE_MODE=feature_native
# Soft credibility reference only (not a hard reject threshold).
ENGINE_TRADE_FLOOR=100
ENGINE_WINDOW_TRADE_FLOORS=all:40,360d:20,90d:10,30d:6
ENGINE_SINGLE_INDICATORS=rsi,macd,bollinger,ema_cross,atr_regime,stoch_rsi,adx,cci
ENGINE_FEATURE_CORES=lmo_core_momentum_pulse,lmo_core_mean_reclaim,lmo_core_breakout_regime,lmo_core_flow_absorption,lmo_core_risk_compression,lmo_core_timing_efficiency
ENGINE_VALIDATION_ENABLED=true
ENGINE_VALIDATION_STRICTNESS=institutional
ENGINE_VALIDATION_WALK_FORWARD_SPLITS=4
ENGINE_VALIDATION_CV_FOLDS=4
ENGINE_VALIDATION_PURGE_BARS=120
ENGINE_VALIDATION_STRESS_FRICTION_BPS=10,20,30
ENGINE_VALIDATION_SAMPLE_STEP=5
# Time-bar Meta-Label Baseline v2 (LogReg only, binary-only objective)
ENGINE_META_LABEL_ENABLED=true
ENGINE_META_LABEL_MODEL=logreg
ENGINE_META_LABEL_OBJECTIVE=classification_binary
ENGINE_META_LABEL_PENALTY=l1
ENGINE_META_LABEL_C=0.25
ENGINE_META_LABEL_MAX_ITER=2500
ENGINE_META_LABEL_CLASS_WEIGHT=balanced
ENGINE_META_LABEL_TP_MULT=1.5
ENGINE_META_LABEL_SL_MULT=1.0
ENGINE_META_LABEL_VERTICAL_HORIZON_BARS=16
ENGINE_META_LABEL_VOL_WINDOW=20
ENGINE_META_LABEL_MIN_EVENTS=80
ENGINE_META_LABEL_THRESHOLD_MIN=0.50
ENGINE_META_LABEL_THRESHOLD_MAX=0.95
ENGINE_META_LABEL_THRESHOLD_STEP=0.01
ENGINE_META_LABEL_PRECISION_FLOOR=0.60
ENGINE_META_LABEL_THRESHOLD_OBJECTIVE=f05
ENGINE_META_LABEL_PROB_THRESHOLD_FALLBACK=0.55
ENGINE_META_LABEL_FEATURE_CAP=3
# ENGINE_META_LABEL_FEATURE_ALLOWLIST=trend__logret__15m,flow_liquidity__shock_density__1m,risk_volatility__realized_vol_60__1m
ENGINE_META_LABEL_CPCV_SPLITS=6
ENGINE_META_LABEL_CPCV_TEST_GROUPS=2
ENGINE_META_LABEL_CPCV_PURGE_BARS=16
ENGINE_META_LABEL_CPCV_EMBARGO_BARS=16
ENGINE_META_LABEL_CPCV_MAX_COMBINATIONS=24
# Optional validation runtime limiter (for fast cloud or laptop tail-pass):
# ENGINE_VALIDATION_LIGHT_MODE=true
# ENGINE_VALIDATION_GATE_MODES=gated
# ENGINE_VALIDATION_MAX_RESULTS=90
ENGINE_MAX_DEPLOY_RULES_PER_SYMBOL=2
ENGINE_RSI_WINDOWS=14,21
ENGINE_RSI_STRATEGIES=mean_revert,breakout,centerline
ENGINE_RSI_LOWER_BOUNDS=30,35
ENGINE_RSI_UPPER_BOUNDS=65,70
ENGINE_FRICTION_BPS=10
ENGINE_GATE_ORACLE_QUANTILE=0.55
ENGINE_GATE_CONFIDENCE_QUANTILE=0.40
ENGINE_CREDIBILITY_REJECT_THRESHOLD=0.65
ENGINE_CREDIBLE_MAX_PENALTY=0.80

# Phase 1 market ingestion (GitHub Actions / server-to-server)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional direct Postgres connection string for DDL (create/alter table).
# Example format:
# SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<db-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
SUPABASE_DB_URL=
INGEST_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
BINANCE_FAPI_BASE_URL=https://fapi.binance.com
ANOMALY_RANGE_THRESHOLD_PCT=5
ANOMALY_OI_DROP_THRESHOLD_PCT=3
BINANCE_HTTP_TIMEOUT_SEC=12
BINANCE_HTTP_RETRIES=3

# Phase 1.2 report generation
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
REPORT_USE_MOCK_LLM=false
REPORT_LOCALES=en,zh-tw
REPORT_HTTP_TIMEOUT_SEC=20
REPORT_HTTP_RETRIES=3
ORACLE_UNIQUE_ENTITY=LeiMai Liquidity Friction

# SEO submit (Google Search Console API)
GSC_SITE_URL=https://leimai.io/
SUPPORT_BASE_URL=https://leimai.io
GOOGLE_SERVICE_ACCOUNT_JSON=

# Phase 3 heartbeat monitor
HEARTBEAT_MAX_AGE_HOURS=5
HEARTBEAT_EVENT_TYPE=oracle_report_pipeline_stale
HEARTBEAT_ENABLE_DISPATCH=true
HEARTBEAT_DISPATCH_WORKFLOW=ingest_4h.yml
HEARTBEAT_DISPATCH_REF=main
HEARTBEAT_HTTP_TIMEOUT_SEC=12
HEARTBEAT_HTTP_RETRIES=3
