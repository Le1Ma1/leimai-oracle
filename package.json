{
  "name": "leimai-oracle",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "support:start": "node support/server.mjs",
    "support:worker": "node support/worker.mjs",
    "support:dev": "node --watch support/server.mjs",
    "support:run-local": "powershell -ExecutionPolicy Bypass -File scripts/support_run_local.ps1",
    "support:stop-local": "powershell -ExecutionPolicy Bypass -File scripts/support_stop_local.ps1",
    "prepare:brand": "node scripts/prepare-brand.mjs",
    "precompute": "tsx scripts/precompute.ts",
    "precompute:hybrid": "tsx scripts/precompute.ts --hybrid",
    "precompute:hybrid-full": "tsx scripts/precompute.ts --hybrid --full-bars",
    "i18n:check": "tsx scripts/i18n-check.ts",
    "test:ui:snapshots": "playwright test",
    "test:ui:update-baseline": "playwright test --update-snapshots",
    "quality:gate": "npm run i18n:check && npm run test:ui:snapshots",
    "predev": "npm run prepare:brand && npm run precompute",
    "dev": "next dev",
    "prebuild": "npm run prepare:brand && npm run precompute",
    "build": "next build",
    "prestart": "npm run prepare:brand",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "next": "14.2.25",
    "png-to-ico": "^3.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "20.17.19",
    "@types/react": "18.3.20",
    "@types/react-dom": "18.3.6",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.25",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "tsx": "^4.20.6",
    "typescript": "5.7.3"
  }
}
